{
  "name": "imec-institucional-premium",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "index.js",
  "scripts": {
    "postinstall": "npm install --prefix frontend",
    "dev": "concurrently \"npm --prefix backend run dev\" \"npm --prefix frontend run dev\"",
    "install:all": "npm install && npm install --prefix frontend",
    "create-admin": "node backend/src/createAdmin.js",
    "build": "npm install --prefix frontend && npm --prefix frontend run build",
    "start": "node index.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.12.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
